<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Sistema QR</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/qr-layout-lectura.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="app-container">

        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <button id="btnToggle" class="btn-toggle">
                    <i class="bi bi-list"></i>
                </button>
            </div>

            <nav class="sidebar-menu">
                <a asp-controller="LectorGenerador" asp-action="Lectura" class="menu-item">
                    <i class="bi bi-qr-code-scan"></i>
                    <span>Lectura QR</span>
                </a>

                <a asp-controller="LectorGenerador" asp-action="Index" class="menu-item">
                    <i class="bi bi-table"></i>
                    <span>Registros</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN -->
        <div class="main-lectura">

            @RenderBody()

            <!-- BOTON ADMIN -->
            <button id="btnAdmin" class="btn-admin-floating">
                Admin
            </button>

            <!-- BOTONES SECRETOS -->
            <div id="adminExitTop" class="admin-exit admin-exit-top"></div>
            <div id="adminExitBottom" class="admin-exit admin-exit-bottom"></div>

        </div>

    </div>

    @RenderSection("Scripts", required: false)
    <script src="~/js/qr-admin.js"></script>

    <script src="~/js/_Layout.js"></script>

</body>
</html>