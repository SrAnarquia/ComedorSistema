<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - QR</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <link href="~/css/qr-layout.css" rel="stylesheet" />
    @RenderSection("Styles", false)
</head>

<body>

    <div class="app-container">

        <!-- SIDEBAR -->
        <aside class="sidebar collapsed">

            <!-- BURGER -->
            <button id="burgerBtn" class="burger-btn sidebar-burger">
                <i class="bi bi-list"></i>
            </button>

            <a asp-action="Lectura"
               asp-controller="LectorGenerador"
               class="menu-item">
                <i class="bi bi-upc-scan"></i>
                <span>Leer QR</span>
            </a>

            <a asp-action="Index"
               asp-controller="LectorGenerador"
               class="menu-item">
                <i class="bi bi-clipboard-data"></i>
                <span>Mis solicitudes</span>
            </a>

        </aside>

        <!-- CONTENIDO -->
        <main class="main-content">

            <!-- TOPBAR -->
            <header class="topbar">

                <button id="btnAdmin" class="btn-admin">
                    <i class="bi bi-shield-lock"></i>
                </button>

                <div id="adminHotspot"></div>
            </header>

            @RenderBody()

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const burgerBtn = document.getElementById("burgerBtn");
        const sidebar = document.querySelector(".sidebar");

        burgerBtn.addEventListener("click", () => {
            sidebar.classList.toggle("collapsed");
        });
    </script>

    <!-- Script Admin (NO TOCAR) -->
    <script src="~/js/qr-admin.js"></script>

    @RenderSection("Scripts", false)

</body>
</html>